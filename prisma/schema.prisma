// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  passwordHash        String

  // Relations
  preferences         UserPreference?
  habits              Habit[]
  favoriteSuggestions UserSuggestionFavorite[]
  refreshTokens       RefreshToken[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserPreference {
  id                   String   @id @default(cuid())
  
  // UI Preferences
  theme                String?  @default("light")
  sidebarCollapsed     Boolean? @default(false)

  // Onboarding Data
  onboardingGoal       String?
  onboardingCommitment String?

  // Relations
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt            DateTime @updatedAt
}

model Habit {
  id                 String       @id @default(cuid())
  title              String
  icon               String
  target             Int
  category           String
  streak             Int          @default(0)
  slug               String
  startDate          DateTime
  trackingStartDate  DateTime?
  order              Int          @default(0)

  // Reminder fields
  reminderEnabled    Boolean?     @default(false)
  reminderTime       String?      // "HH:MM" format

  // Status fields
  isActive           Boolean?     @default(true)
  isCompleted        Boolean?     @default(false)
  isArchived         Boolean?     @default(false)
  deletedAt          DateTime?    // For soft deletes and cloud sync

  // Scheduling
  frequency          Frequency?   @default(DAILY)
  customFrequency    Json?        // { daysOfWeek?: number[], interval?: number }

  // Relations
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  history            HabitEntry[]

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([userId, slug])
  @@index([userId, deletedAt])
}

model HabitEntry {
  id        String    @id @default(cuid())
  date      DateTime  // the completed date
  deletedAt DateTime? // For soft deletes and cloud sync
  habitId   String
  habit     Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)

  updatedAt DateTime  @default(now()) @updatedAt

  @@unique([habitId, date]) // prevent duplicate entries for same day
  @@index([habitId, deletedAt])
}

enum Frequency {
  DAILY
  WEEKLY
  CUSTOM
}

model Suggestion {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String

  // Relations
  favoritedBy UserSuggestionFavorite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model UserSuggestionFavorite {
  userId       String
  suggestionId String

  // Relations
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())

  @@id([userId, suggestionId])
}
